// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  username  String    @unique
  avatar    String?
  createdAt DateTime  @default(now())
  bookings  Booking[]
}

model Listing {
  id             Int       @id @default(autoincrement())
  title          String
  location       String
  pricePerNight  Float
  guests         Int
  createdAt      DateTime  @default(now())
  bookings       Booking[]
  
}

model Booking {
  id          Int      @id @default(autoincrement())
  checkIn     DateTime
  totalPrice  Float
  status      String
  guestId     Int
  listingId   Int
  createdAt   DateTime @default(now())
  guestById   User     @relation(fields: [guestId], references: [id])
  listing     Listing  @relation(fields: [listingId], references: [id])
}
enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}
enum UserRole {
  USER
  ADMIN
}
enum ListingType {
  APARTMENT
  HOUSE
  ROOM
}
enum PaymentMethod {
  CREDIT_CARD
  PAYPAL
  STRIPE
}
enum  bookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

